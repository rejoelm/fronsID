## Vault Encryption (Client-Side)

### Key Derivation
```typescript
// lib/vault-encryption.ts

async function deriveVaultKeys(passphrase: string, walletSignature: Uint8Array) {
    const salt = new Uint8Array([...walletSignature.slice(0, 16)]);

    // Master key via PBKDF2
    const keyMaterial = await crypto.subtle.importKey(
        'raw', new TextEncoder().encode(passphrase), 'PBKDF2', false, ['deriveBits']
    );
    const masterBits = await crypto.subtle.deriveBits(
        { name: 'PBKDF2', salt, iterations: 100000, hash: 'SHA-512' },
        keyMaterial, 512
    );

    // Sub-keys via HKDF
    const masterKey = await crypto.subtle.importKey(
        'raw', masterBits, 'HKDF', false, ['deriveBits']
    );
    const fekBits = await crypto.subtle.deriveBits(
        { name: 'HKDF', hash: 'SHA-256', salt: new Uint8Array(0),
          info: new TextEncoder().encode('file-encryption') },
        masterKey, 256
    );
    const mekBits = await crypto.subtle.deriveBits(
        { name: 'HKDF', hash: 'SHA-256', salt: new Uint8Array(0),
          info: new TextEncoder().encode('metadata-encryption') },
        masterKey, 256
    );

    return {
        fek: await crypto.subtle.importKey('raw', fekBits, 'AES-GCM', false, ['encrypt','decrypt']),
        mek: await crypto.subtle.importKey('raw', mekBits, 'AES-GCM', false, ['encrypt','decrypt']),
    };
}

async function encryptFile(file: ArrayBuffer, fek: CryptoKey) {
    const nonce = crypto.getRandomValues(new Uint8Array(12)); // 96-bit
    const encrypted = await crypto.subtle.encrypt(
        { name: 'AES-GCM', iv: nonce }, fek, file
    );
    return { encrypted, nonce, authTag: encrypted.slice(-16) };
}

async function decryptFile(encrypted: ArrayBuffer, nonce: Uint8Array, fek: CryptoKey) {
    return await crypto.subtle.decrypt(
        { name: 'AES-GCM', iv: nonce }, fek, encrypted
    );
}
```

### Upload Flow
```
1. User selects file in browser
2. Browser computes SHA-256 hash of original file
3. Browser encrypts file with FEK (AES-256-GCM, random nonce)
4. Browser encrypts metadata (name, tags, description) with MEK
5. Encrypted blob uploaded to Walrus → returns blob_id
6. Metadata saved to Supabase (encrypted fields + blob_id + hash)
7. SHA-256 hash recorded on Solana for integrity proof
8. Gas spent from user's escrow
```

### Recovery
```
1. User enters 12-word recovery phrase
2. Phrase → seed → wallet signature (deterministic)
3. Signature used as PBKDF2 entropy → same master key
4. Sub-keys derived → same FEK and MEK
5. All files decryptable
```

