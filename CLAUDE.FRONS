    rev_author NUMERIC(10,6) DEFAULT 0,
    rev_sharing_pool NUMERIC(10,6) DEFAULT 0,
    rev_protocol_reserve NUMERIC(10,6) DEFAULT 0,
    dataset_id UUID,
